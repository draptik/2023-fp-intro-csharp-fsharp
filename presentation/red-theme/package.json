{
  "name": "slidev-theme-red",
  "version": "0.0.0",
  "engines": {
    "node": ">=16.0.0",
    "slidev": ">=0.19.3"
  },
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "//": "Learn more: https://sli.dev/themes/write-a-theme.html",
  "slidev": {
    "colorSchema": "light",
    "highlighter": "all",
    "defaults": {
      "hightlighter": "prism"
    }
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@slidev/types": "52.14.1",
    "codemirror-theme-vars": "0.1.2",
    "prism-theme-vars": "0.2.5",
    "theme-vitesse": "1.0.0"
  },
  "devDependencies": {
    "@slidev/cli": "52.14.1"
  }
}